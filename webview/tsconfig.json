{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@tasks": [
        "../src/tasks/index.ts"
      ],
      "@tasks/*": [
        "../src/tasks/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "../src/tasks/**/*.ts"
  ]
}