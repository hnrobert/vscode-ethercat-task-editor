{
  "publisher": "HNRobert",
  "name": "vscode-ethercat-task-editor",
  "displayName": "EtherCAT Task Editor",
  "description": "Visual editor for SOEM YAML config files based on MSG format.",
  "version": "0.0.3",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hnrobert/vscode-ethercat-task-editor"
  },
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "icon": "assets/images/icon.png",
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "ethercat-yaml",
        "aliases": [
          "EtherCAT Task Config",
          "EtherCAT YAML"
        ],
        "extensions": [],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ethercat-yaml",
        "scopeName": "source.ethercat-yaml",
        "path": "./syntaxes/ethercat-yaml.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[ethercat-yaml]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnSave": false
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "entity.name.tag.ethercat.sdowrite",
            "settings": {
              "foreground": "#4EC9B0"
            }
          },
          {
            "scope": "entity.name.tag.ethercat.pdo",
            "settings": {
              "foreground": "#febb5d"
            }
          },
          {
            "scope": "entity.name.tag.ethercat.conf",
            "settings": {
              "foreground": "#DCDCAA"
            }
          },
          {
            "scope": "keyword.control.ethercat",
            "settings": {
              "foreground": "#C586C0"
            }
          },
          {
            "scope": "variable.parameter.ethercat.motor",
            "settings": {
              "foreground": "#9CDCFE"
            }
          },
          {
            "scope": "variable.parameter.ethercat.pid",
            "settings": {
              "foreground": "#B5CEA8"
            }
          },
          {
            "scope": "support.type.property-name.ethercat.topic",
            "settings": {
              "foreground": "#00ffff"
            }
          },
          {
            "scope": "entity.name.type.ethercat.sn",
            "settings": {
              "foreground": "#28cdff",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "entity.name.function.ethercat.app",
            "settings": {
              "foreground": "#fcff66",
              "fontStyle": "bold"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.string",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.uint8",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.uint16",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.uint32",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.int8",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.int16",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.int32",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "storage.type.ethercat.tag.float",
            "settings": {
              "foreground": "#808080"
            }
          },
          {
            "scope": "invalid.illegal.ethercat.tag",
            "settings": {
              "foreground": "#F44747",
              "fontStyle": "italic underline"
            }
          }
        ]
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ethercatTaskEditor-container",
          "title": "EtherCAT Task Editor",
          "icon": "assets/images/icon-stroke.svg"
        }
      ]
    },
    "views": {
      "ethercatTaskEditor-container": [
        {
          "id": "ethercatTaskEditor.sidebar",
          "name": "EtherCAT Task Editor",
          "type": "webview",
          "icon": "assets/images/icon-stroke.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ethercatTaskEditor.refresh",
        "title": "Recalculate Offsets & Lengths",
        "icon": "$(refresh)"
      },
      {
        "command": "ethercatTaskEditor.collapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)"
      },
      {
        "command": "ethercatTaskEditor.expandAll",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "ethercatTaskEditor.showPanel",
        "title": "Open EtherCAT Config",
        "icon": "assets/images/icon-stroke-outline.svg"
      },
      {
        "command": "ethercatTaskEditor.configureFileIcon",
        "title": "Configure EtherCAT File Icon"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ethercatTaskEditor.collapseAll",
          "when": "view == ethercatTaskEditor.sidebar",
          "group": "navigation@2"
        },
        {
          "command": "ethercatTaskEditor.expandAll",
          "when": "view == ethercatTaskEditor.sidebar",
          "group": "navigation@3"
        },
        {
          "command": "ethercatTaskEditor.refresh",
          "when": "view == ethercatTaskEditor.sidebar",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "ethercatTaskEditor.showPanel",
          "when": "ethercatTaskEditor.isEthercatYaml",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsup && vite build --config webview/vite.config.ts",
    "build:ext": "tsup",
    "build:webview": "vite build --config webview/vite.config.ts",
    "watch": "tsup --watch",
    "watch:webview": "vite build --config webview/vite.config.ts --watch"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/vscode": "^1.104.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.8",
    "vue": "^3.5.32"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}