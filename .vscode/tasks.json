{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "pnpm: build",
      "command": "pnpm run build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "shell",
      "label": "pnpm: watch",
      "command": "pnpm run watch",
      "problemMatcher": [
        {
          "owner": "tsup",
          "source": "tsup",
          "fileLocation": "autoDetect",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Build start.*$",
            "endsPattern": "^.*Build success.*$"
          },
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+): error: (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    },
    {
      "type": "shell",
      "label": "pnpm: watch webview",
      "command": "pnpm run watch:webview",
      "problemMatcher": [
        {
          "owner": "vite",
          "source": "vite",
          "fileLocation": "autoDetect",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*vite.*$",
            "endsPattern": "^.*built in.*$"
          },
          "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+): error: (.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "message": 4
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": "build"
    }
  ]
}